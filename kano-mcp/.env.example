# Base URL of the Kano API, including the /api/v1 prefix.
# `docker compose up` maps the API container's port 5000 to host port 5001,
# so from the host (where this MCP server runs) the API lives at :5001.
KANO_API_BASE=http://localhost:5001/api/v1

# --- MCP transport (how clients connect to THIS server) ---------------------
# stdio (default)  -> host launches the server as a subprocess (Claude Desktop/Code).
# streamable-http  -> run as an HTTP service; clients connect to http://HOST:PORT/mcp.
# sse              -> legacy HTTP transport at http://HOST:PORT/sse.
KANO_MCP_TRANSPORT=stdio
KANO_MCP_HOST=127.0.0.1
KANO_MCP_PORT=8000
