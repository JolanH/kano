# Copy to .env for local development. Never commit .env.
# Values below are placeholders — fill in per environment.
#
# Authoritative source of truth: POSTGRES_USER / POSTGRES_PASSWORD /
# POSTGRES_DB. The docker-compose.yml interpolates DATABASE_URL from these
# three values, so editing the password here is enough — there is no
# separate DATABASE_URL to keep in sync for the docker workflow.
#
# A DATABASE_URL is only required when running the backend OUTSIDE compose
# (e.g. `cd kano-backend && poetry run flask run`); see the "Without Docker"
# section of README.md for the recipe.

# PostgreSQL credentials (consumed by both the DB container and the backend)
POSTGRES_USER=kano
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kano

# Flask runtime mode: development | production
FLASK_ENV=development

# Application version (semantic; surfaced in /healthz and structured logs)
KANO_VERSION=0.1.0

# Comma-separated list of origins allowed by Flask-CORS (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Flask secret key — must be a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Respondent off-ramp contact (Story 3-8). Surfaced on the expired + not-found
# poll surfaces as a mailto: anchor. Frontend Vite picks this up at build time.
VITE_PRODUCT_CONTACT_EMAIL=product@tixeo.com

# Public base URL used to assemble shareable poll URLs in PollSharePanel.
# Leave unset for same-origin v1 deployments (PM SPA + respondent SPA share a
# host) — the panel falls back to `window.location.origin`. Set explicitly for
# split-origin staging, dev tunnels, or future deploys where the respondent
# surface lives on a separate hostname.
# VITE_PUBLIC_BASE_URL=https://kano.example.com
